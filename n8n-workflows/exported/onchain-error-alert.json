  "nodes": [
    {
      "parameters": {
        "content": "## onchain-error-alert\nError Trigger → **Normalize Input** (Set: owns the error-payload→named-fields contract, with fallbacks so nothing renders `undefined`) → Telegram. Set as the `errorWorkflow` for onchain-* workflows; fires a Telegram alert (chat 207209924) on any failure. To change what the alert shows, edit Normalize Input — not the Telegram node. Owner: onchain-intel.",
        "height": 180,
        "width": 460
      },
      "id": "sticky",
      "name": "Overview",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -48,
        -208
      ]
    },
    {
      "parameters": {},
      "id": "err_trig",
      "name": "On workflow error",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "chatId": "207209924",
        "text": "=🔴 onchain-intel: workflow FAILED\nWorkflow: {{ $('Normalize Input').first().json.workflow_name }}\nLast node: {{ $('Normalize Input').first().json.last_node }}\nError: {{ $('Normalize Input').first().json.error_message }}\nExecution: {{ $('Normalize Input').first().json.execution_id }} ({{ $('Normalize Input').first().json.execution_mode }})\nTime: {{ $('Normalize Input').first().json.alerted_at }}",
        "additionalFields": {
          "appendAttribution": false
        }
      },
      "id": "tg_alert",
      "name": "Telegram alert",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        460,
        0
      ],
      "webhookId": "ed90f63e-31f6-43c7-8d2d-258ac6bab541",
      "credentials": {
        "telegramApi": {
          "id": "cMrsUr48jl2JVEUi",
          "name": "Onchain bot"
        }
      }
    },
    {
      "id": "set-normalize",
      "name": "Normalize Input",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        220,
        0
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "c-workflow-name",
              "name": "workflow_name",
