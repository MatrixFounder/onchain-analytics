{
  "name": "@onchain-intel/mcp-server",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "onchain-intel-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke:dist": "node scripts/smoke-dist.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@onchain-intel/core": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
