              "type": "string"
            },
            {
              "id": "c-workflow-id",
              "name": "workflow_id",
              "value": "={{ $('On workflow error').first().json.workflow?.id || 'unknown' }}",
              "type": "string"
            },
            {
              "id": "c-last-node",
              "name": "last_node",
              "value": "={{ $('On workflow error').first().json.execution?.lastNodeExecuted || '(unknown)' }}",
              "type": "string"
            },
            {
              "id": "c-error-message",
              "name": "error_message",
              "value": "={{ $('On workflow error').first().json.execution?.error?.message || 'no message' }}",
              "type": "string"
            },
            {
              "id": "c-execution-id",
              "name": "execution_id",
              "value": "={{ $('On workflow error').first().json.execution?.id || 'n/a' }}",
              "type": "string"
            },
            {
              "id": "c-execution-url",
              "name": "execution_url",
              "value": "={{ $('On workflow error').first().json.execution?.url || '' }}",
              "type": "string"
            },
            {
              "id": "c-execution-mode",
              "name": "execution_mode",
              "value": "={{ $('On workflow error').first().json.execution?.mode || 'unknown' }}",
              "type": "string"
            },
            {
